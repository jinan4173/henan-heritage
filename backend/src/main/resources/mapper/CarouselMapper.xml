<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.CarouselMapper">
    
    <resultMap id="BaseResultMap" type="com.henan.heritage.entity.Carousel">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="image_url" property="imageUrl" />
        <result column="order_num" property="orderNum" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>
    
    <select id="list" resultMap="BaseResultMap">
        SELECT *
        FROM carousel
        ORDER BY order_num ASC, id ASC
    </select>
    
    <select id="getById" resultMap="BaseResultMap">
        SELECT *
        FROM carousel
        WHERE id = #{id}
    </select>
    
    <insert id="add" parameterType="com.henan.heritage.entity.Carousel">
        INSERT INTO carousel (title, image_url, order_num, status)
        VALUES (#{title}, #{imageUrl}, #{orderNum}, #{status})
    </insert>
    
    <update id="update" parameterType="com.henan.heritage.entity.Carousel">
        UPDATE carousel
        SET title = #{title}, 
            image_url = #{imageUrl}, 
            order_num = #{orderNum}, 
            status = #{status}
        WHERE id = #{id}
    </update>
    
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM carousel WHERE id = #{id}
    </delete>
    
    <select id="getEnabledList" resultMap="BaseResultMap">
        SELECT *
        FROM carousel
        WHERE status = 1
        ORDER BY order_num ASC, id ASC
    </select>
</mapper>
