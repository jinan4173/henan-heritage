<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.PromotionMapper">
    <resultMap id="PromotionResult" type="com.henan.heritage.entity.Promotion">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="coverImage" column="cover_image"/>
        <result property="videoUrl" column="video_url"/>
        <result property="linkUrl" column="link_url"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.henan.heritage.entity.Promotion">
        INSERT INTO promotion (title, content, cover_image, video_url, link_url, type, status, create_time, update_time) 
        VALUES (#{title}, #{content}, #{coverImage}, #{videoUrl}, #{linkUrl}, #{type}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.henan.heritage.entity.Promotion">
        UPDATE promotion SET 
            title = #{title}, 
            content = #{content}, 
            cover_image = #{coverImage}, 
            video_url = #{videoUrl}, 
            link_url = #{linkUrl}, 
            type = #{type}, 
            status = #{status}, 
            update_time = NOW() 
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM promotion WHERE id = #{id}
    </delete>

    <delete id="deleteBatch" parameterType="java.util.List">
        DELETE FROM promotion WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectById" resultMap="PromotionResult">
        SELECT * FROM promotion WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="PromotionResult">
        SELECT * FROM promotion ORDER BY create_time DESC
    </select>

    <select id="selectByPage" resultMap="PromotionResult">
        SELECT * FROM promotion
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND title LIKE CONCAT('%', #{keyword}, '%')
        </if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="count" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM promotion
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND title LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </select>
</mapper>