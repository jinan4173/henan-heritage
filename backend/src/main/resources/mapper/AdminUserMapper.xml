<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.AdminUserMapper">
    <select id="findByUsername" resultType="com.henan.heritage.entity.AdminUser">
        SELECT * FROM system_admin WHERE username = #{username}
    </select>
    <select id="selectById" resultType="com.henan.heritage.entity.AdminUser">
        SELECT * FROM system_admin WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.henan.heritage.entity.AdminUser">
        INSERT INTO system_admin (username, password, create_time, update_time) VALUES (#{username}, #{password}, NOW(), NOW())
    </insert>
    <update id="update" parameterType="com.henan.heritage.entity.AdminUser">
        UPDATE system_admin SET username = #{username}, password = #{password}, update_time = NOW() WHERE id = #{id}
    </update>
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM system_admin WHERE id = #{id}
    </delete>
</mapper>