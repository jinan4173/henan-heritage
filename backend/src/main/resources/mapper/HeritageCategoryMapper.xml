<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.HeritageCategoryMapper">
    <select id="selectList" resultType="com.henan.heritage.entity.HeritageCategory">
        SELECT * FROM heritage_category ORDER BY id ASC
    </select>
    <select id="selectById" resultType="com.henan.heritage.entity.HeritageCategory">
        SELECT * FROM heritage_category WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.henan.heritage.entity.HeritageCategory">
        INSERT INTO heritage_category (name, description, create_time, update_time) VALUES (#{name}, #{description}, NOW(), NOW())
    </insert>
    <update id="update" parameterType="com.henan.heritage.entity.HeritageCategory">
        UPDATE heritage_category SET name = #{name}, description = #{description}, update_time = NOW() WHERE id = #{id}
    </update>
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM heritage_category WHERE id = #{id}
    </delete>
</mapper>