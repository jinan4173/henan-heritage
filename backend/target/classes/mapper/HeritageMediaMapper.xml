<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.HeritageMediaMapper">
    <resultMap id="HeritageMediaResultMap" type="com.henan.heritage.entity.HeritageMedia">
        <id property="id" column="id"/>
        <result property="heritageItemId" column="heritage_item_id"/>
        <result property="mediaType" column="media_type"/>
        <result property="mediaUrl" column="media_url"/>
        <result property="source" column="source"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectByHeritageItemId" parameterType="java.lang.Long" resultMap="HeritageMediaResultMap">
        SELECT * FROM heritage_media WHERE heritage_item_id = #{heritageItemId} ORDER BY create_time DESC
    </select>

    <select id="selectById" parameterType="java.lang.Long" resultMap="HeritageMediaResultMap">
        SELECT * FROM heritage_media WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.henan.heritage.entity.HeritageMedia">
        INSERT INTO heritage_media (heritage_item_id, media_type, media_url, source, description, create_time)
        VALUES (#{heritageItemId}, #{mediaType}, #{mediaUrl}, #{source}, #{description}, NOW())
    </insert>

    <update id="update" parameterType="com.henan.heritage.entity.HeritageMedia">
        UPDATE heritage_media SET
            media_type = #{mediaType},
            media_url = #{mediaUrl},
            source = #{source},
            description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM heritage_media WHERE id = #{id}
    </delete>

    <delete id="deleteByHeritageItemId" parameterType="java.lang.Long">
        DELETE FROM heritage_media WHERE heritage_item_id = #{heritageItemId}
    </delete>
</mapper>
