<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.InheritorMapper">
    <resultMap id="BaseResultMap" type="com.henan.heritage.entity.Inheritor">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="gender" property="gender" />
        <result column="nation" property="nation" />
        <result column="title" property="title" />
        <result column="category" property="category" />
        <result column="status" property="status" />
        <result column="create_time" property="createdAt" />
        <result column="update_time" property="updatedAt" />
    </resultMap>

    <sql id="Base_Column_List">
        id, name, gender, nation, title, category, status, create_time, update_time
    </sql>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM inheritor
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM inheritor
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.henan.heritage.entity.Inheritor">
        INSERT INTO inheritor
        (name, gender, nation, title, category, status, create_time, update_time)
        VALUES
        (#{name}, #{gender}, #{nation}, #{title}, #{category}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.henan.heritage.entity.Inheritor">
        UPDATE inheritor
        SET
        name = #{name},
        gender = #{gender},
        nation = #{nation},
        title = #{title},
        category = #{category},
        status = #{status},
        update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM inheritor
        WHERE id = #{id}
    </delete>

    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM inheritor
        WHERE status = 1
    </select>
</mapper>
