<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.henan.heritage.mapper.RegionMapper">
    <select id="selectList" resultType="com.henan.heritage.entity.Region">
        SELECT * FROM region ORDER BY id ASC
    </select>
    <select id="selectById" resultType="com.henan.heritage.entity.Region">
        SELECT * FROM region WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.henan.heritage.entity.Region">
        INSERT INTO region (name, create_time, update_time) VALUES (#{name}, NOW(), NOW())
    </insert>
    <update id="update" parameterType="com.henan.heritage.entity.Region">
        UPDATE region SET name = #{name}, update_time = NOW() WHERE id = #{id}
    </update>
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM region WHERE id = #{id}
    </delete>
</mapper>